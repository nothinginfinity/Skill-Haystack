{
  "name": "skill-haystack",
  "version": "0.2.0",
  "description": "Single-skill haystack benchmark for LLM routing reliability",
  "scripts": {
    "bench": "ts-node src/runner.ts",
    "bench:openai":    "HAYSTACK_PROVIDER=openai    ts-node src/runner.ts",
    "bench:groq":      "HAYSTACK_PROVIDER=groq      ts-node src/runner.ts",
    "bench:gemini":    "HAYSTACK_PROVIDER=gemini    ts-node src/runner.ts",
    "bench:anthropic": "HAYSTACK_PROVIDER=anthropic ts-node src/runner.ts",
    "bench:xai":       "HAYSTACK_PROVIDER=xai       ts-node src/runner.ts",
    "bench:mistral":   "HAYSTACK_PROVIDER=mistral   ts-node src/runner.ts",
    "bench:deepseek":  "HAYSTACK_PROVIDER=deepseek  ts-node src/runner.ts",
    "bench:cerebras":  "HAYSTACK_PROVIDER=cerebras  ts-node src/runner.ts",
    "bench:fireworks": "HAYSTACK_PROVIDER=fireworks ts-node src/runner.ts",
    "bench:sambanova": "HAYSTACK_PROVIDER=sambanova ts-node src/runner.ts",
    "bench:stub":      "HAYSTACK_PROVIDER=stub      ts-node src/runner.ts",
    "bench:all": "for provider in openai groq gemini anthropic xai mistral deepseek cerebras fireworks sambanova; do HAYSTACK_PROVIDER=$provider ts-node src/runner.ts || true; done"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["llm", "benchmark", "routing", "eval", "haystack"],
  "license": "MIT"
}

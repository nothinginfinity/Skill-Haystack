# Skill-Haystack — API Keys
# Copy to .env and fill in the keys for the providers you want to use.
# .env is gitignored — never commit real keys.

# Set the default provider (can also be passed via --provider CLI arg)
HAYSTACK_PROVIDER=groq

# Provider API keys — only the ones you use need to be set
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=
SAMBANOVA_API_KEY=
